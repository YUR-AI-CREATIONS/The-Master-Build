import os
import time
import traceback
from google import genai
import openai
import anthropic

# Initialize all clients from environment variables
GEMINI_KEY = os.getenv("GEMINI_API_KEY")
OPENAI_KEY = os.getenv("OPENAI_API_KEY")
ANTHROPIC_KEY = os.getenv("ANTHROPIC_API_KEY")

g_client = genai.Client(api_key=GEMINI_KEY)
openai.api_key = OPENAI_KEY
a_client = anthropic.Anthropic(api_key=ANTHROPIC_KEY)

def trinity_engine(prompt, max_tokens=500):
    """
    Runs prompt through Gemini → OpenAI → Anthropic in failover order.
    Returns best response with metadata.
    """

    def run_gemini():
        start = time.time()
        r = g_client.models.generate_content(
            model="models/gemini-2.5-pro",
            contents=prompt
        )
        return {
            "engine": "Gemini",
            "text": r.text.strip(),
            "latency": round(time.time() - start, 2)
        }

    def run_openai():
        start = time.time()
        r = openai.ChatCompletion.create(
            model="gpt-4o-mini",
            messages=[{"role": "user", "content": prompt}],
            max_tokens=max_tokens
        )
        return {
            "engine": "OpenAI",
            "text": r.choices[0].message.content.strip(),
            "latency": round(time.time() - start, 2)
        }

    def run_anthropic():
        start = time.time()
        r = a_client.messages.create(
            model="claude-sonnet-4-5-20250929",
            max_tokens=max_tokens,
            messages=[{"role": "user", "content": prompt}]
        )
        return {
            "engine": "Anthropic",
            "text": r.content[0].text.strip(),
            "latency": round(time.time() - start, 2)
        }

    # Failover logic
    for fn in [run_gemini, run_openai, run_anthropic]:
