import os
import sys
import json
import argparse
from datetime import datetime
from google import genai
from openai import OpenAI
import anthropic

# ==============================================
#   FRANKLIN OS MULTIMODAL ENGINE - CORE
# ==============================================

# -- Environment Setup --
GEMINI_API_KEY = os.getenv("GEMINI_API_KEY")
OPENAI_API_KEY = os.getenv("OPENAI_API_KEY")
ANTHROPIC_API_KEY = os.getenv("ANTHROPIC_API_KEY")

if not all([GEMINI_API_KEY, OPENAI_API_KEY, ANTHROPIC_API_KEY]):
    raise Exception("Missing API keys. Run: setx GEMINI_API_KEY X, setx OPENAI_API_KEY Y, setx ANTHROPIC_API_KEY Z")

gemini = genai.Client(api_key=GEMINI_API_KEY)
openai_client = OpenAI(api_key=OPENAI_API_KEY)
claude = anthropic.Anthropic(api_key=ANTHROPIC_API_KEY)

# -- Utility: Log every interaction for traceability --
def log_interaction(source, input_text, output_text):
    timestamp = datetime.utcnow().isoformat()
    log_entry = {"timestamp": timestamp, "source": source, "input": input_text, "output": output_text}
    os.makedirs("logs", exist_ok=True)
    with open(f"logs/{source}_log.jsonl", "a", encoding="utf-8") as f:
        f.write(json.dumps(log_entry) + "\n")

# ==============================================
#   ENGINE MODES
# ==============================================

def run_gemini(prompt, mode="text"):
    if mode == "text":
        response = gemini.models.generate_content(model="models/gemini-2.5-pro", contents=prompt)
        output = response.text
    elif mode == "image":
        response = gemini.models.generate_images(model="models/imagen-4.0-generate-001", prompt=prompt)
        image_path = f"outputs/gemini_{datetime.utcnow().timestamp()}.png"
        os.makedirs("outputs", exist_ok=True)
        with open(image_path, "wb") as f:
            f.write(response.images[0].data)
        output = f"✅ Image saved: {image_path}"
    elif mode == "audio":
        from google.cloud import texttospeech
        tts_client = texttospeech.TextToSpeechClient()
        synthesis_input = texttospeech.SynthesisInput(text=prompt)
        voice = texttospeech.VoiceSelectionParams(language_code="en-US", name="en-US-Studio-O")
        audio_config = texttospeech.AudioConfig(audio_encoding=texttospeech.AudioEncoding.MP3)
        audio_response = tts_client.synthesize_speech(input=synthesis_input, voice=voice, audio_config=audio_config)
        audio_path = f"outputs/gemini_tts_{datetime.utcnow().timestamp()}.mp3"
        with open(audio_path, "wb") as out:
            out.write(audio_response.audio_content)
        output = f"✅ Audio saved: {audio_path}"
    else:
        output = "❌ Unsupported Gemini mode"
    log_interaction("Gemini", prompt, output)
    return output


def run_chatgpt(prompt):
    response = openai_client.chat.completions.create(
        model="gpt-4o",
        messages=[{"role": "user", "content": prompt}]
    )
    output = response.choices[0].message.content
    log_interaction("ChatGPT", prompt, output)
    return output


def run_claude(prompt):
    response = claude.messages.create(
        model="claude-3-opus-20240229",
        max_tokens=2048,
        messages=[{"role": "user", "content": prompt}]
    )
    output = response.content[0].text
    log_interaction("Claude", prompt, output)
    return output


def run_sentinel(prompt):
    """Simulated Sentinel AI: verifies truth, coherence, and tone."""
    sentinel_report = {
        "coherence_score": 0.98,
        "bias_check": "clean",
        "timestamp": datetime.utcnow().isoformat(),
        "verdict": "✅ Pass — Truth and tone validated."
    }
    log_interaction("Sentinel", prompt, sentinel_report)
    return sentinel_report

# ==============================================
#   MAIN EXECUTION ROUTER
# ==============================================

def franklin_router(engine, prompt, mode="text"):
    if engine == "gemini":
        return run_gemini(prompt, mode)
    elif engine == "chatgpt":
        return run_chatgpt(prompt)
    elif engine == "claude":
        return run_claude(prompt)
    elif engine == "sentinel":
        return run_sentinel(prompt)
    else:
        return "❌ Unknown engine"

# ==============================================
#   CLI ENTRYPOINT
# ==============================================

if __name__ == "__main__":
    parser = argparse.ArgumentParser(description="Franklin OS Multimodal AI Engine")
    parser.add_argument("--engine", required=True, help="AI engine: gemini | chatgpt | claude | sentinel")
    parser.add_argument("--prompt", required=True, help="Prompt to process")
    parser.add_argument("--mode", default="text", help="Mode for Gemini: text | image | audio")
    args = parser.parse_args()

    output = franklin_router(args.engine.lower(), args.prompt, args.mode.lower())
    print(output)
