# ==========================================
# VIDEO GENERATION
# ==========================================
elif mode == "video":
    response = client.models.generate_videos(
        model="models/veo-3.1-generate-preview",
        prompt=prompt
    )
    video_bytes = response.generated_videos[0].video.video_bytes
    with open("output_video.mp4", "wb") as f:
        f.write(video_bytes)
    print("✅ Video saved as output_video.mp4")

# ==========================================
# AUDIO GENERATION (Google Cloud TTS)
# ==========================================
elif mode == "audio":
    try:
        tts_client = texttospeech.TextToSpeechClient()
        synthesis_input = texttospeech.SynthesisInput(text=prompt)
        voice = texttospeech.VoiceSelectionParams(
            language_code="en-US",
            name="en-US-Studio-O",
        )
        audio_config = texttospeech.AudioConfig(audio_encoding=texttospeech.AudioEncoding.MP3)
        response = tts_client.synthesize_speech(
            input=synthesis_input, voice=voice, audio_config=audio_config
        )
        with open("output_audio.mp3", "wb") as out:
            out.write(response.audio_content)
        print("✅ Audio saved as output_audio.mp3")
    except Exception as e:
        print("⚠️ TTS Error:", e)

# ==========================================
# EMBEDDINGS
# ==========================================
elif mode == "embed":
    embedding = client.models.embed_content(model="models/text-embedding-004", content=prompt)
    print("✅ Embedding vector length:", len(embedding.embeddings[0].values))

else:
