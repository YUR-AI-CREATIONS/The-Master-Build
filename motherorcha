/**
 * Cosmic Comic Book Creator - Unified Backend Scaffold
 * Drop this into your /functions directory.
 * Replace the API keys below and run:
 *   npm install firebase-admin firebase-functions @google/generative-ai axios
 *   firebase deploy --only functions
 */

import * as functions from "firebase-functions";
import * as admin from "firebase-admin";
import axios from "axios";
import { GoogleGenerativeAI } from "@google/generative-ai";

// ---- CONFIG ---- //
const GEMINI_KEY = process.env.VITE_GEMINI_API_KEY || "YOUR_GEMINI_KEY";
const VO3_KEY = process.env.VO3_API_KEY || "YOUR_VO3_KEY";

if (!admin.apps.length) admin.initializeApp();
const db = admin.firestore();

const genAI = new GoogleGenerativeAI(GEMINI_KEY);
const model = genAI.getGenerativeModel({ model: "gemini-pro" });

// ---------- CORE ROUTER ----------
export const runAI = functions.https.onCall(async (data, context) => {
  const { taskType, input } = data;
  let output = "";
  let modelUsed = "gemini-pro";

  try {
    switch (taskType) {
      case "story":
        output = await generateStory(input);
        break;
      case "dialogue":
        output = await refineDialogue(input);
        break;
      case "visual":
        output = await generateVisual(input);
        modelUsed = "VO3";
        break;
      case "game":
        output = await generateGameScene(input);
        break;
      case "child":
        output = await interpretChildPrompt(input);
        break;
      default:
        throw new Error(`Unknown taskType: ${taskType}`);
    }

    const logRef = db.collection("logs").doc();
    await logRef.set({
      taskType,
      input,
      output,
      modelUsed,
      timestamp: admin.firestore.FieldValue.serverTimestamp(),
    });

    return { success: true, output };
  } catch (err: any) {
    console.error(err);
    return { success: false, error: err.message };
  }
});

// ---------- TASKS ----------
async function generateStory(prompt: string): Promise<string> {
  const pre = `Create a short, vivid comic story panel.
  Keep it under 150 words.
  Include hero, conflict, and cosmic imagery.`;
  const result = await model.generateContent(pre + "\n" + prompt);
  return result.response.text();
}

async function refineDialogue(input: string): Promise<string> {
  const pre = `You are a comic dialogue enhancer.
  Rewrite the lines with humor and energy.`;
  const result = await model.generateContent(pre + "\n" + input);
  return result.response.text();
}

async function interpretChildPrompt(input: string): Promise<string> {
  const pre = `A child just said: "${input}".
  Convert this into a structured comic panel description.
  Be playful and imaginative.`;
  const result = await model.generateContent(pre);
  return result.response.text();
}

async function generateGameScene(input: string): Promise<string> {
  const pre = `Create a branching comic game scene with 3 choices.
  Each choice changes the outcome.
  Be concise, colorful, and engaging.`;
  const result = await model.generateContent(pre + "\n" + input);
  return result.response.text();
}

async function generateVisual(prompt: string): Promise<string> {
  const veoPrompt = { prompt, resolution: "720p", duration: 5 };
  const response = await axios.post(
    "https://api.vo3.ai/v1/generate",
    veoPrompt,
    { headers: { Authorization: `Bearer ${VO3_KEY}` } }
  );
  return response.data.videoUrl || "No video generated.";
}

