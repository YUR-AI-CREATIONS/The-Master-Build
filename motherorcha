        "OpenAI": run_openai,
        "Anthropic": run_anthropic
    }
    ordered = [primary] + [e for e in engines if e != primary]
    
    log_entry = {"prompt": prompt, "results": [], "timestamp": time.strftime("%Y-%m-%d %H:%M:%S")}
    
