import os
import requests
import time
from fastapi import FastAPI
from pydantic import BaseModel
from jinja2 import Template

COINGECKO_BASE = "https://api.coingecko.com/api/v3"
ETHERSCAN_API = os.getenv("ETHERSCAN_KEY")  # put your key in env
app = FastAPI()

# ---------- Helpers ----------
def fetch_top_coins(vs_currency="usd", per_page=10):
    r = requests.get(f"{COINGECKO_BASE}/coins/markets",
                     params={"vs_currency": vs_currency, "order": "market_cap_desc", "per_page": per_page, "page": 1})
    r.raise_for_status()
    return r.json()

def check_contract_verified(chain, contract):
    # For MVP we'll support Ethereum (etherscan)
    if chain != "ethereum" or not ETHERSCAN_API:
        return {"verified": None, "reason": "no-api-or-unsupported-chain"}
    url = "https://api.etherscan.io/api"
    params = {"module": "contract", "action": "getsourcecode", "address": contract, "apikey": ETHERSCAN_API}
    r = requests.get(url, params=params)
    j = r.json()
    if j.get("status") == "1" and j.get("result"):
        src = j["result"][0]
        verified = bool(src.get("SourceCode"))
        return {"verified": verified, "compiler": src.get("CompilerVersion"), "abi": bool(src.get("ABI"))}
    return {"verified": False, "reason": j}

def simple_rug_score(coin):
    # coin is a CoinGecko coin object with 'id' and 'platforms'
    score = 50  # starting neutral
    # Market cap heuristic
    mcap = coin.get("market_cap") or 0
    if mcap < 100_000: score -= 20
    elif mcap < 1_000_000: score -= 10
    else: score += 5

    # Contract verification
    platforms = coin.get("platforms") or {}
    eth_addr = platforms.get("ethereum")
    if eth_addr:
        v = check_contract_verified("ethereum", eth_addr)
        if v.get("verified") is True:
            score += 10
        elif v.get("verified") is False:
            score -= 20
    else:
        # No contract on ethereum (could be token on other chain or native coin)
        score += 0

    # Age: if launched very recently, penalize a little (CoinGecko provides 'atl_date' not always)
    # We'll skip exact age in this MVP.

    score = max(0, min(100, score))
    return {"score": score, "market_cap": mcap, "contract": eth_addr if eth_addr else None}

# ---------- Newsletter template ----------
NEWSLETTER_TEMPLATE = """
<h1>CryptoPulse — Daily</h1>
<p>Snapshot at {{ ts }}</p>
<ul>
{% for item in coins %}
  <li>
    <strong>{{ item['name'] }} ({{ item['symbol'] }})</strong> — Market Cap: ${{ "{:,.0f}".format(item['market_cap']) if item['market_cap'] else "N/A" }}
    <br/>Score: {{ item['rug']['score'] }} — Contract: {{ item['rug']['contract'] }}
    <p>{{ item['description'] }}</p>
  </li>
{% endfor %}
</ul>
"""

# ---------- FastAPI endpoints ----------
class PromptIn(BaseModel):
    prompt: str

@app.get("/coins/top")
def coins_top():
    coins = fetch_top_coins(per_page=10)
    simplified = []
    for c in coins:
        rug = simple_rug_score(c)
        simplified.append({
            "id": c["id"],
            "symbol": c["symbol"],
            "name": c["name"],
            "market_cap": c.get("market_cap"),
            "current_price": c.get("current_price"),
            "rug": rug,
            "description": c.get("id")  # placeholder
        })
    return {"timestamp": time.time(), "coins": simplified}

@app.post("/newsletter/generate")
def newsletter_generate(body: PromptIn):
    coins = fetch_top_coins(per_page=8)
    for c in coins:
        c["rug"] = simple_rug_score(c)
        c["description"] = c.get("id")
    html = Template(NEWSLETTER_TEMPLATE).render(ts=time.ctime(), coins=coins)
    # For MVP return HTML; in prod you'd send email via SendGrid
    return {"html": html}

