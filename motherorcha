def run_gemini(prompt, max_tokens=600):
    start = time.time()
    r = g_client.models.generate_content(model="models/gemini-2.5-pro", contents=prompt)
    return {
        "engine": "Gemini",
        "text": r.text.strip(),
        "latency": round(time.time() - start, 2),
        "confidence": 0.90
    }

def run_openai(prompt, max_tokens=600):
    start = time.time()
    r = openai.ChatCompletion.create(
        model="gpt-4o-mini",
        messages=[{"role": "user", "content": prompt}],
        max_tokens=max_tokens
    )
    return {
        "engine": "OpenAI",
        "text": r.choices[0].message.content.strip(),
        "latency": round(time.time() - start, 2),
        "confidence": 0.92
    }

def run_anthropic(prompt, max_tokens=600):
    start = time.time()
    r = a_client.messages.create(
        model="claude-sonnet-4-5-20250929",
        max_tokens=max_tokens,
        messages=[{"role": "user", "content": prompt}]
    )
    return {
