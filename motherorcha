    """Routes prompt based on linguistic and contextual cues."""
    lower = prompt.lower()
    if any(k in lower for k in ["image", "video", "render", "design", "storyboard", "scene", "visualize"]):
        return "Gemini"
    if any(k in lower for k in ["analyze", "summarize", "compare", "calculate", "data", "report"]):
        return "OpenAI"
    if any(k in lower for k in ["philosophy", "ethics", "meaning", "truth", "law", "sovereign", "spiritual"]):
        return "Anthropic"
    return "OpenAI"  # default to OpenAI for general-purpose tasks

